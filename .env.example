# ===== AnnotateMe Environment Configuration =====
# Copy this file to .env and fill in your values

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=annotateme
DB_PASSWORD=change_me_strong_password_here
DB_NAME=annotateme

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT Auth ----
# Must be at least 32 characters, use a random string
JWT_SECRET=change_me_minimum_32_chars_random_string_here_abc123

# ---- MinIO / Object Storage ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET=annotateme
MINIO_USE_SSL=false

# ---- App ----
PORT=3000
NODE_ENV=development
UPLOAD_DIR=./uploads

# ---- Domain / Deployment ----
# Leave blank for local development (everything defaults to localhost).
# Set to your domain name for production deployments, e.g:
#   APP_DOMAIN=enhancebiz.ai
# When set:
#   - Nginx serves on that server_name
#   - Grafana dashboard is reachable at https://<APP_DOMAIN>/grafana/
#   - Password reset emails link to https://<APP_DOMAIN>/reset-password?token=...
APP_DOMAIN=

# ---- CORS (comma-separated origins, or * for all) ----
# Automatically set to https://<APP_DOMAIN> when APP_DOMAIN is configured.
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80

# ---- Email / SMTP (for password reset) ----
# Leave blank to use dev mode (reset link is returned in the API response).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@annotateme.com

# ---- Grafana ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password
