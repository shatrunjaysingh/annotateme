DB_HOST=localhost
DB_PORT=5432
DB_USER=annotateme
DB_PASSWORD=annotateme
DB_NAME=annotateme
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_change_in_production
PORT=3000

# Domain — leave blank for localhost, set to your domain for production (e.g. enhancebiz.ai)
APP_DOMAIN=

# SMTP — leave blank to use dev mode (reset link returned in API response)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@annotateme.com
